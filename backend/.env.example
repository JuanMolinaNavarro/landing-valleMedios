NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:4321,http://192.168.0.100:4321

SQL_SERVER=127.0.0.1
SQL_PORT=1433
SQL_DATABASE=ISP_DB
SQL_USER=sa
SQL_PASSWORD=YourStrongPassword
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true
SQL_CONNECTION_TIMEOUT_MS=15000
SQL_REQUEST_TIMEOUT_MS=15000
SQL_POOL_MAX=10
SQL_POOL_MIN=1
SQL_POOL_IDLE_TIMEOUT_MS=30000

SESSION_COOKIE_NAME=isp_portal_session
SESSION_SECRET=change_this_for_production
SESSION_TTL_MINUTES=720
COOKIE_SECURE=false
COOKIE_DOMAIN=

PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_NO_SANDBOX=true

APP_NAME=Valle Medios
