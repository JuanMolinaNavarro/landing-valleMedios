NODE_ENV=production
PORT=3001

# URL publica del sitio (frontend) separadas por coma si hay varias.
# Ejemplo: https://portal.vallemedios.com.ar,https://www.portal.vallemedios.com.ar
CORS_ORIGIN=http://localhost

SQL_SERVER=127.0.0.1
SQL_PORT=1433
SQL_DATABASE=ISP_DB
SQL_USER=sa
SQL_PASSWORD=change_me
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true
SQL_CONNECTION_TIMEOUT_MS=15000
SQL_REQUEST_TIMEOUT_MS=15000
SQL_POOL_MAX=10
SQL_POOL_MIN=1
SQL_POOL_IDLE_TIMEOUT_MS=30000

SESSION_COOKIE_NAME=isp_portal_session
SESSION_SECRET=change_me_to_a_long_random_secret
SESSION_TTL_MINUTES=720
COOKIE_SECURE=false
COOKIE_DOMAIN=

PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_NO_SANDBOX=true

APP_NAME=Valle Medios
