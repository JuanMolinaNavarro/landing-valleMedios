---
// Navbar.astro
const navLinks = [
  { href: "#inicio", label: "Inicio" },
  { href: "#servicios", label: "Servicios" },
  { href: "#planes", label: "Planes" },
  // { href: "#cobertura", label: "Cobertura" },
  { href: "#contacto", label: "Contacto" },
];
---

<header class="navbar" id="navbar">
  <div class="nav-container container">
    <a href="#inicio" class="nav-logo" aria-label="Valle Medios — Inicio">
      <img
        src="/img/Providers valle medios FO - Horizontal.png"
        alt="Valle Medios Fibra Óptica"
        class="logo-img"
        width="auto"
        height="80"
      />
    </a>

    <nav
      class="nav-links"
      id="nav-links"
      role="navigation"
      aria-label="Menú principal"
    >
      {
        navLinks.map(({ href, label }) => (
          <a href={href} class="nav-link">
            {label}
          </a>
        ))
      }
      <a href="/login" class="nav-link nav-link--portal-mobile">
        Portal de Abonados
      </a>
    </nav>

    <a href="/login" class="btn-portal" id="btn-portal-nav"
      >Portal de Abonados</a
    >
    <a href="#planes" class="btn-contratar" id="btn-contratar-nav"
      >Contratar Ahora</a
    >

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="nav-links"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    min-height: var(--nav-h);
    height: 80px;
    background: rgba(255, 255, 255, 0.97);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: box-shadow var(--transition);
  }
  .navbar.scrolled {
    box-shadow: 0 2px 24px rgba(0, 0, 0, 0.18);
  }

  .nav-container {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .logo-img {
    height: 150px;
    width: auto;
    max-width: 340px;
    object-fit: contain;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    margin: 0 auto;
  }

  .nav-link {
    color: #1a1a1a;
    font-size: 0.95rem;
    font-weight: 500;
    padding: 8px 14px;
    border-radius: 8px;
    transition:
      background var(--transition),
      color var(--transition),
      font-weight var(--transition);
  }
  .nav-link:hover,
  .nav-link.active {
    background: rgba(0, 0, 0, 0.06);
    color: #000;
  }

  .btn-contratar {
    background: #0a0a0a;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 10px 22px;
    border-radius: 8px;
    white-space: nowrap;
    flex-shrink: 0;
    transition:
      background var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }
  .btn-contratar:hover {
    background: #333;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  .btn-portal {
    background: transparent;
    color: #0a0a0a;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 10px 16px;
    border-radius: 8px;
    border: 1px solid rgba(0, 0, 0, 0.2);
    white-space: nowrap;
    margin-right: 10px;
    flex-shrink: 0;
    transition:
      background var(--transition),
      border-color var(--transition),
      transform var(--transition);
  }
  .btn-portal:hover {
    background: rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.35);
    transform: translateY(-1px);
  }

  .nav-link--portal-mobile {
    display: none;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: 12px;
    flex-shrink: 0;
  }
  .hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: #1a1a1a;
    border-radius: 2px;
    transition:
      transform var(--transition),
      opacity var(--transition);
  }
  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: fixed;
      top: var(--nav-h);
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.98);
      flex-direction: column;
      padding: 20px 24px;
      gap: 4px;
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }
    .nav-links.open {
      display: flex;
    }
    .nav-link {
      padding: 12px 14px;
      font-size: 1rem;
    }
    .btn-contratar {
      display: none;
    }
    .btn-portal {
      display: none;
    }
    .nav-link--portal-mobile {
      display: block;
      margin-top: 8px;
      text-align: center;
      font-weight: 600;
      border: 1px solid rgba(0, 0, 0, 0.12);
      border-radius: 8px;
    }
    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  // Scroll effect
  const navbar = document.getElementById("navbar")!;
  const onScroll = () =>
    navbar.classList.toggle("scrolled", window.scrollY > 30);
  window.addEventListener("scroll", onScroll, { passive: true });

  // Hamburger toggle
  const hamburger = document.getElementById("hamburger")!;
  const navLinks = document.getElementById("nav-links")!;
  hamburger.addEventListener("click", () => {
    const isOpen = navLinks.classList.toggle("open");
    hamburger.setAttribute("aria-expanded", String(isOpen));
  });

  // Close on link click
  navLinks.querySelectorAll<HTMLAnchorElement>(".nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      navLinks.classList.remove("open");
      hamburger.setAttribute("aria-expanded", "false");
    });
  });

  // Active link highlight on scroll
  const sections = document.querySelectorAll<HTMLElement>("section[id]");
  const links = navLinks.querySelectorAll<HTMLAnchorElement>(".nav-link");
  const highlight = () => {
    const y = window.scrollY + 100;
    sections.forEach((section) => {
      if (
        y >= section.offsetTop &&
        y < section.offsetTop + section.offsetHeight
      ) {
        links.forEach((l) => l.classList.remove("active"));
        const active = navLinks.querySelector<HTMLAnchorElement>(
          `[href="#${section.id}"]`,
        );
        active?.classList.add("active");
      }
    });
  };
  window.addEventListener("scroll", highlight, { passive: true });
</script>
