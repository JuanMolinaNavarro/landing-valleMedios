---
interface ContactItem {
  id: string;
  icon: string;
  title: string;
  detail: string;
  href?: string;
}

const directChannels: ContactItem[] = [
  {
    id: "ci-whatsapp",
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
    title: "WhatsApp",
    detail: "+54 9 381 236 7037",
    href: "https://wa.me/5493812367037?text=Hola%2C%20quiero%20informacion%20sobre%20el%20servicio.",
  },
  {
    id: "ci-telefono",
    icon: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.13 12.72 19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>`,
    title: "Telefono",
    detail: "0810 555 9434",
    href: "tel:08105559434",
  },
];

const supportInfo: ContactItem[] = [
  {
    id: "ci-horarios",
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
    title: "Horarios de atencion",
    detail: "Lun-Vie 09:00-13:00 y 16:00-20:00\nSab 09:00-13:00",
  },
  {
    id: "ci-zona",
    icon: `<circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.5 8 14 8 14s8-8.5 8-14a8 8 0 0 0-8-8z"/>`,
    title: "Direccion",
    detail:
      "Av. Calchaqui - Galeria Las Quenuas - Local 9, Tafi del Valle, Tucuman, Argentina",
  },
];
---

<section class="contacto section-dark" id="contacto">
  <div class="container">
    <header class="section-header reveal">
      <span class="section-tag">Contacto</span>
      <h2 class="section-title">Estamos para ayudarte</h2>
      <p class="section-subtitle">
        Elegi un canal directo para hablar con el equipo y resolver tu consulta
        en el momento.
      </p>
    </header>

    <div class="contacto-grid">
      <article class="contact-panel reveal">
        <h3 class="panel-title">Canales directos</h3>
        <p class="panel-copy">
          La forma mas rapida de contactarnos es por WhatsApp o telefono.
        </p>

        <div class="quick-list">
          {
            directChannels.map(({ id, icon, title, detail, href }) => (
              <a
                class="quick-item"
                id={id}
                href={href}
                target={href?.startsWith("http") ? "_blank" : undefined}
                rel={href?.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                <div class="contact-icon" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    set:html={icon}
                  />
                </div>
                <div>
                  <p class="quick-label">{title}</p>
                  <p class="quick-detail">{detail}</p>
                </div>
              </a>
            ))
          }
        </div>
      </article>

      <aside class="contact-info reveal">
        <h3 class="panel-title">Informacion util</h3>
        <p class="panel-copy">
          Acercate personalmente a nuestra sucursal.
        </p>
        <div class="info-list">
          {
            supportInfo.map(({ id, icon, title, detail }) => (
              <div class="contact-item" id={id}>
                <div class="contact-icon" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    set:html={icon}
                  />
                </div>
                <div>
                  <h4>{title}</h4>
                  <p>{detail}</p>
                </div>
              </div>
            ))
          }
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .contacto {
    padding: 100px 0;
  }

  .contacto-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 32px;
    align-items: stretch;
  }

  .contact-panel,
  .contact-info {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 28px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .panel-title {
    margin: 0;
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--off-white);
  }

  .panel-copy {
    margin: 10px 0 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .quick-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 22px;
  }

  .quick-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px;
    border-radius: 10px;
    border: 1px solid var(--border);
    text-decoration: none;
    transition:
      border-color var(--transition),
      background var(--transition),
      transform var(--transition);
  }

  .quick-item:hover {
    border-color: rgba(79, 195, 247, 0.4);
    background: rgba(79, 195, 247, 0.08);
    transform: translateY(-2px);
  }

  .quick-label {
    margin: 0;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--off-white);
  }

  .quick-detail {
    margin: 6px 0 0;
    color: var(--muted);
  }

  .info-list {
    margin-top: 22px;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    background: rgba(79, 195, 247, 0.1);
    border: 1px solid rgba(79, 195, 247, 0.2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-icon svg {
    width: 20px;
    height: 20px;
    stroke: var(--accent);
  }

  .contact-item h4 {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--off-white);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .contact-item p {
    margin: 6px 0 0;
    color: var(--muted);
    line-height: 1.6;
    white-space: pre-line;
  }

  @media (max-width: 900px) {
    .contacto-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
