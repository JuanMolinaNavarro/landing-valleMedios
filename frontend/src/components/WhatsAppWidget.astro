---
const whatsappUrl =
  "https://wa.me/5493812367037?text=Hola%2C%20%C2%BFc%C3%B3mo%20est%C3%A1n%3F%20Quiero%20consultar%20acerca%20del%20servicio%20de%20internet%20y%20cable.";
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-widget"
  aria-label="Hablar por WhatsApp"
>
  <span class="wa-icon" aria-hidden="true">&#128172;</span>
  <span class="wa-text">Hablar por WhatsApp</span>
</a>

<style>
  .whatsapp-widget {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background:
      linear-gradient(
        135deg,
        rgba(37, 211, 102, 0.22),
        rgba(37, 211, 102, 0.1)
      ),
      rgba(18, 24, 22, 0.38);
    backdrop-filter: blur(12px) saturate(170%);
    -webkit-backdrop-filter: blur(12px) saturate(170%);
    color: #ffffff;
    padding: 11px 16px;
    border-radius: 999px;
    border: 1px solid rgba(190, 255, 218, 0.35);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.92rem;
    box-shadow:
      0 10px 26px rgba(12, 20, 17, 0.45),
      0 0 0 1px rgba(255, 255, 255, 0.07) inset,
      0 0 18px rgba(37, 211, 102, 0.22);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease;
  }

  .wa-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    font-size: 0.95rem;
    line-height: 1;
  }

  .wa-text {
    letter-spacing: 0.01em;
  }

  .whatsapp-widget:hover {
    background:
      linear-gradient(
        135deg,
        rgba(37, 211, 102, 0.3),
        rgba(37, 211, 102, 0.15)
      ),
      rgba(18, 24, 22, 0.44);
    border-color: rgba(211, 255, 227, 0.55);
    transform: translateY(-2px) scale(1.01);
    box-shadow:
      0 14px 34px rgba(12, 20, 17, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.11) inset,
      0 0 24px rgba(37, 211, 102, 0.28);
  }

  @media (max-width: 480px) {
    .whatsapp-widget {
      right: 12px;
      bottom: 12px;
      padding: 10px 13px;
      font-size: 0.85rem;
      gap: 8px;
    }

    .wa-icon {
      width: 22px;
      height: 22px;
      font-size: 0.9rem;
    }
  }
</style>
