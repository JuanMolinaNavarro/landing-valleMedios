---
const whatsappUrl =
  "https://wa.me/5493812367037?text=Hola%2C%20%C2%BFc%C3%B3mo%20est%C3%A1n%3F%20Quiero%20contratar%20el%20servicio%20de%20internet.%20%C2%BFPodr%C3%ADan%20enviarme%20informaci%C3%B3n%20sobre%20planes%2C%20precios%20y%20disponibilidad%20en%20mi%20zona%3F";
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-widget"
  aria-label="Hablar por WhatsApp"
>
  <span aria-hidden="true">&#128172;</span>
  <span>Hablar por WhatsApp</span>
</a>

<style>
  .whatsapp-widget {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #25d366;
    color: #ffffff;
    padding: 10px 15px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.92rem;
    box-shadow: 0 10px 24px rgba(37, 211, 102, 0.35);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
  }

  .whatsapp-widget:hover {
    background: #20bd5b;
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(37, 211, 102, 0.4);
  }

  @media (max-width: 480px) {
    .whatsapp-widget {
      right: 12px;
      bottom: 12px;
      padding: 10px 13px;
      font-size: 0.85rem;
    }
  }
</style>
