---
// Hero.astro
---

<section class="hero" id="inicio" aria-label="Sección principal">
  <!-- Background -->
  <div class="hero-bg" aria-hidden="true">
    <img
      src="/img/hero.jpg"
      alt=""
      class="hero-bg-img"
      width="1920"
      height="1080"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
    <div class="hero-geo-shapes">
      <div class="geo-shape geo-shape-1"></div>
      <div class="geo-shape geo-shape-2"></div>
      <div class="geo-shape geo-shape-3"></div>
    </div>
  </div>

  <!-- Content -->
  <div class="hero-content container">
    <!-- Columna izquierda: texto -->
    <div class="hero-text">
      <span class="hero-badge">
        <svg
          class="wifi-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12.55a11 11 0 0 1 14.08 0"></path>
          <path d="M1.42 9a16 16 0 0 1 21.16 0"></path>
          <path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path>
          <line x1="12" y1="20" x2="12.01" y2="20"></line>
        </svg>
        Fibra Óptica
      </span>

      <h1 class="hero-title">
        Conectividad a la<br />
        <em class="hero-title-italic">velocidad</em> del valle
      </h1>

      <p class="hero-desc">
        Internet de alta velocidad con fibra óptica. Disfruta de una<br />
        conexión estable y rápida para tu hogar o negocio.
      </p>

      <div class="hero-cta">
        <a href="#contacto" class="btn-primary" id="btn-ver-planes"
          >Consultar Servicio &rarr;</a
        >
        {
          /* <a href="#cobertura" class="btn-secondary" id="btn-cobertura"
          >Consultar Cobertura</a
        > */
        }
      </div>

      <div class="hero-stats" aria-label="Estadísticas de servicio">
        <div class="stat">
          <span class="stat-number" data-target="99.9" data-suffix="%"
            >99.9%</span
          >
          <span class="stat-label">Uptime</span>
        </div>
        <div class="stat">
          <span class="stat-number" data-target="1000" data-suffix="+"
            >1000+</span
          >
          <span class="stat-label">Clientes</span>
        </div>
      </div>
    </div>

    <!-- Columna derecha: logo -->
    <div class="hero-logo-wrap" aria-hidden="true">
      <img
        src="/img/vallemediosVertical.png"
        alt=""
        class="hero-logo"
        width="auto"
        height="200"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: var(--nav-h);
  }

  /* --- Background --- */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: grayscale(100%) brightness(0.55);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.82) 0%,
      rgba(0, 0, 0, 0.55) 50%,
      rgba(0, 0, 0, 0.18) 100%
    );
  }

  /* Geometric dark shapes 
  .hero-geo-shapes {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 220px;
    overflow: hidden;
    pointer-events: none;
  }
  .geo-shape {
    position: absolute;
    background: rgba(0, 0, 0, 1);
  }
  .geo-shape-1 {
    bottom: 0;
    left: -5%;
    width: 45%;
    height: 160px;
    clip-path: polygon(0 100%, 100% 10%, 100% 100%);
  }
  .geo-shape-2 {
    bottom: 0;
    left: 30%;
    width: 40%;
    height: 120px;
    clip-path: polygon(0 100%, 100% 0%, 100% 100%, 0 100%);
  }
  .geo-shape-3 {
    bottom: 0;
    right: -2%;
    width: 35%;
    height: 90px;
    clip-path: polygon(0 5%, 100% 100%, 0 100%);
    background: rgba(0, 0, 0, 1);
  }*/

  /* --- Content (2 columnas) --- */
  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    padding-top: 40px;
    padding-bottom: 180px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
  }

  /* Columna izquierda */
  .hero-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    max-width: 580px;
  }

  /* Columna derecha: logo */
  .hero-logo-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeInUp 0.6s 0.3s both;
  }
  .hero-logo {
    height: clamp(220px, 30vw, 420px);
    width: auto;
    filter: brightness(0) invert(1)
      drop-shadow(0 4px 40px rgba(255, 255, 255, 0.25));
    opacity: 1;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 24px;
    letter-spacing: 0.02em;
    animation: fadeInUp 0.6s 0.1s both;
  }
  .wifi-icon {
    width: 18px;
    height: 18px;
  }

  /* Title */
  .hero-title {
    font-size: clamp(2.8rem, 6vw, 4.6rem);
    font-weight: 800;
    line-height: 1.08;
    color: var(--white);
    letter-spacing: -0.025em;
    margin-bottom: 20px;
    animation: fadeInUp 0.6s 0.25s both;
  }
  .hero-title-italic {
    font-style: italic;
  }

  /* Desc */
  .hero-desc {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.75;
    margin-bottom: 36px;
    max-width: 480px;
    animation: fadeInUp 0.6s 0.4s both;
  }

  /* CTA */
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 56px;
    animation: fadeInUp 0.6s 0.52s both;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: flex-start;
    gap: 48px;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s 0.65s both;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .stat-number {
    font-size: 1.9rem;
    font-weight: 800;
    color: var(--white);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .stat-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .hero-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 40px;
      padding-bottom: 120px;
    }
    .hero-logo-wrap {
      order: -1;
      width: 100%;
      justify-content: flex-start;
    }
    .hero-logo {
      height: clamp(80px, 14vw, 130px);
    }
    .hero-text {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .hero-logo-wrap {
      display: none;
    }
    .hero-cta {
      flex-direction: column;
      align-items: flex-start;
    }
    .hero-geo-shapes {
      display: none;
    }
    .hero-stats {
      gap: 32px;
    }
    .stat-number {
      font-size: 1.6rem;
    }
  }
</style>

<script>
  // Counter animation
  function animateCounter(el: HTMLElement, target: number, suffix: string) {
    const start = performance.now();
    const duration = 1800;
    const step = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(eased * target * 10) / 10 + suffix;
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  const statsEl = document.querySelector(".hero-stats");
  if (statsEl) {
    const obs = new IntersectionObserver(
      (entries) => {
        if (!entries[0].isIntersecting) return;
        obs.disconnect();
        document
          .querySelectorAll<HTMLElement>("[data-target]")
          .forEach((el) => {
            const target = parseFloat(el.dataset.target!);
            const suffix = el.dataset.suffix ?? "";
            animateCounter(el, target, suffix);
          });
      },
      { threshold: 0.5 },
    );
    obs.observe(statsEl);
  }
</script>
