---
import PortalLayout from "../../layouts/PortalLayout.astro";
---

<PortalLayout title="Mis Facturas">
  <div class="p-page-header">
    <div class="p-container">
      <h1 class="p-page-title">Mis Facturas</h1>
      <p class="p-page-subtitle" id="facturas-subtitle">Consultá el historial de tus facturas</p>
    </div>
  </div>

  <div class="p-container facturas-body">
    <!-- Estado: cargando -->
    <div id="state-loading" class="p-loader">
      <div class="p-spinner"></div>
      <span>Cargando facturas…</span>
    </div>

    <!-- Estado: error -->
    <div id="state-error" class="p-alert p-alert--error facturas-alert" hidden role="alert">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
        <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span id="state-error-msg">No se pudieron cargar las facturas.</span>
    </div>

    <!-- Estado: sin resultados -->
    <div id="state-empty" class="p-empty" hidden>
      <div class="p-empty__icon">🧾</div>
      <p class="p-empty__title">No tenés facturas disponibles</p>
      <p class="p-empty__desc">Cuando se genere tu próxima factura, la verás aquí.</p>
    </div>

    <!-- Estado: listado de facturas -->
    <div id="state-data" class="p-card facturas-card" hidden>
      <div class="facturas-card__top">
        <p class="facturas-count" id="facturas-count"></p>
      </div>
      <div id="facturas-desktop-list" class="facturas-desktop-list" aria-label="Listado de facturas"></div>
      <div id="facturas-mobile-list" class="facturas-mobile-list" aria-label="Listado compacto de facturas"></div>
    </div>
  </div>

  <script>
    import { getMe, getFacturas, getFacturaDetalle, getPdfUrl, formatPeso, ApiRequestError } from "../../lib/api.ts";
    import type { FacturaResumen, FacturaDeuda } from "../../lib/api.ts";

    const stateLoading = document.getElementById("state-loading")!;
    const stateError = document.getElementById("state-error")!;
    const stateErrorMsg = document.getElementById("state-error-msg")!;
    const stateEmpty = document.getElementById("state-empty")!;
    const stateData = document.getElementById("state-data")!;
    const desktopList = document.getElementById("facturas-desktop-list")!;
    const mobileList = document.getElementById("facturas-mobile-list")!;
    const facturaCount = document.getElementById("facturas-count")!;
    const subtitle = document.getElementById("facturas-subtitle")!;

    type FacturaEstado = "Pagada" | "Adeudada";
    type FacturaListItem = FacturaResumen & {
      estado: FacturaEstado;
      isLatest: boolean;
    };

    function show(el: HTMLElement) { el.hidden = false; }
    function hide(el: HTMLElement) { el.hidden = true; }

    function deudaKey(nroCbte: number, tipoFac: string): string {
      return `${nroCbte}-${tipoFac.trim().toUpperCase()}`;
    }

    function getEstadoPill(estado: FacturaEstado): string {
      return estado === "Adeudada"
        ? `<span class="status-pill status-pill--deuda">Adeudada</span>`
        : `<span class="status-pill status-pill--pagada">Pagada</span>`;
    }

    function getFechaVisible(f: FacturaResumen): string {
      return f.fecEmision ?? f.fecVto1 ?? "—";
    }

    function showError(msg: string) {
      hide(stateLoading); hide(stateEmpty); hide(stateData);
      stateErrorMsg.textContent = msg;
      show(stateError);
    }

    function getBadgeTipo(tipoFac: string): string {
      return tipoFac === "A"
        ? `<span class="p-badge p-badge--orange">Tipo A</span>`
        : `<span class="p-badge p-badge--blue">Tipo ${tipoFac}</span>`;
    }

    function renderDesktopCard(f: FacturaListItem): string {
      const pdfUrl = getPdfUrl(f.nroCbte, f.tipoFac);
      const detailUrl = `/facturas/${f.nroCbte}/${f.tipoFac}`;
      const importe = formatPeso(f.impNetoVto1);
      const badge = getBadgeTipo(f.tipoFac);
      const estado = getEstadoPill(f.estado);
      const fecha = getFechaVisible(f);
      const vto = f.fecVto1 ?? "—";
      const periodo = f.periodo ?? "—";

      return `
        <article class="factura-desktop ${f.isLatest ? "factura-desktop--latest" : ""}" aria-label="Factura ${f.nroCbte}">
          <div class="factura-desktop__main">
            <div class="factura-desktop__identity">
              <span class="factura-desktop__meta">Comprobante</span>
              <span class="factura-desktop__cbte">N° ${f.nroCbte}</span>
              <div class="factura-desktop__badges">
                ${badge}
                ${f.isLatest ? `<span class="latest-mark latest-mark--desktop">
                  <svg class="latest-mark__icon" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 3l2.7 5.47 6.03.88-4.36 4.25 1.03 6-5.4-2.84-5.4 2.84 1.03-6-4.36-4.25 6.03-.88L12 3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  </svg>
                  Ultima emitida
                </span>` : ""}
              </div>
            </div>
            <div class="factura-desktop__grid">
              <div class="factura-datum">
                <span class="factura-datum__label">Fecha emisión</span>
                <span class="factura-datum__value">${fecha}</span>
              </div>
              <div class="factura-datum">
                <span class="factura-datum__label">Vencimiento</span>
                <span class="factura-datum__value">${vto}</span>
              </div>
              <div class="factura-datum">
                <span class="factura-datum__label">Período</span>
                <span class="factura-datum__value">${periodo}</span>
              </div>
            </div>
            <div class="factura-desktop__summary">
              <span class="factura-desktop__importe-label">Importe</span>
              <span class="factura-desktop__importe">${importe}</span>
              ${estado}
            </div>
          </div>
          <div class="factura-desktop__actions">
            <a
              href="${detailUrl}"
              class="p-btn p-btn--outline p-btn--sm"
              aria-label="Ver detalle de factura ${f.nroCbte}"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
              </svg>
              Ver detalle
            </a>
            <a
              href="${pdfUrl}"
              target="_blank"
              rel="noopener noreferrer"
              class="p-btn p-btn--ghost p-btn--sm"
              aria-label="Abrir PDF de factura ${f.nroCbte}"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="2"/>
                <polyline points="14,2 14,8 20,8" stroke="currentColor" stroke-width="2"/>
              </svg>
              PDF
            </a>
          </div>
        </article>
      `;
    }

    function renderMobileCard(f: FacturaListItem): string {
      const pdfUrl = getPdfUrl(f.nroCbte, f.tipoFac);
      const detailUrl = `/facturas/${f.nroCbte}/${f.tipoFac}`;
      const importe = formatPeso(f.impNetoVto1);
      const estado = getEstadoPill(f.estado);
      const fecha = getFechaVisible(f);
      const vto = f.fecVto1 ?? "—";
      const periodo = f.periodo ?? "—";

      return `
        <article class="factura-item ${f.isLatest ? "factura-item--latest" : ""}" aria-label="Factura ${f.nroCbte}">
          <div class="factura-item__top">
            <div class="factura-item__identity">
              <span class="factura-item__meta">Comprobante</span>
              <span class="factura-item__cbte">N° ${f.nroCbte}</span>
            </div>
            <div class="factura-item__status">${estado}</div>
          </div>
          <div class="factura-item__badges">
            ${getBadgeTipo(f.tipoFac)}
            ${f.isLatest ? `<span class="latest-mark latest-mark--mobile">
              <svg class="latest-mark__icon" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 3l2.7 5.47 6.03.88-4.36 4.25 1.03 6-5.4-2.84-5.4 2.84 1.03-6-4.36-4.25 6.03-.88L12 3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
              </svg>
              Ultima emitida
            </span>` : ""}
          </div>
          <div class="factura-item__grid">
            <div class="factura-kv">
              <span class="factura-kv__label">Fecha emisión</span>
              <span class="factura-kv__value">${fecha}</span>
            </div>
            <div class="factura-kv">
              <span class="factura-kv__label">Vencimiento</span>
              <span class="factura-kv__value">${vto}</span>
            </div>
            <div class="factura-kv">
              <span class="factura-kv__label">Período</span>
              <span class="factura-kv__value">${periodo}</span>
            </div>
            <div class="factura-kv factura-kv--importe">
              <span class="factura-kv__label">Importe</span>
              <span class="factura-kv__value">${importe}</span>
            </div>
          </div>
          <div class="factura-item__footer">
            <div class="factura-item__actions">
              <a
                href="${detailUrl}"
                class="p-btn p-btn--outline p-btn--sm factura-item__detail-btn"
                aria-label="Ver detalle de factura ${f.nroCbte}"
              >
                Ver detalle
              </a>
              <a
                href="${pdfUrl}"
                target="_blank"
                rel="noopener noreferrer"
                class="p-btn p-btn--ghost p-btn--sm"
                aria-label="Abrir PDF de factura ${f.nroCbte}"
              >
                PDF
              </a>
            </div>
          </div>
        </article>
      `;
    }

    async function init() {
      // 1) Autenticación
      try {
        const user = await getMe();
        subtitle.textContent = `Hola, ${user.nombre.split(",")[0] ?? user.nombre}`;
      } catch (e) {
        if (e instanceof ApiRequestError && e.statusCode === 401) {
          window.location.href = "/login";
          return;
        }
        showError("Error al verificar la sesión.");
        return;
      }

      // 2) Facturas
      try {
        const facturasRaw = await getFacturas();
        const facturasOrdenadas = [...facturasRaw].sort((a, b) => Number(b.nroCbte) - Number(a.nroCbte));
        const ultimasFacturas = facturasOrdenadas.slice(0, 6);

        hide(stateLoading);

        if (!ultimasFacturas.length) {
          show(stateEmpty);
          return;
        }

        const masReciente = ultimasFacturas[0];
        const detalleMasReciente = await getFacturaDetalle(masReciente.nroCbte, masReciente.tipoFac);
        const deudaSet = new Set(
          (detalleMasReciente.deuda ?? []).map((d: FacturaDeuda) => deudaKey(Number(d.nroCbte), d.tipoFac)),
        );

        const facturasConEstado: FacturaListItem[] = ultimasFacturas.map((f, index) => ({
          ...f,
          estado: deudaSet.has(deudaKey(Number(f.nroCbte), f.tipoFac)) ? "Adeudada" : "Pagada",
          isLatest: index === 0,
        }));

        const mostradas = facturasConEstado.length;
        facturaCount.textContent = mostradas === 1
          ? "Ultima factura del abonado"
          : `Ultimas ${mostradas} facturas del abonado`;

        desktopList.innerHTML = facturasConEstado.map(renderDesktopCard).join("");
        mobileList.innerHTML = facturasConEstado.map(renderMobileCard).join("");
        show(stateData);
      } catch (e) {
        if (e instanceof ApiRequestError && e.statusCode === 401) {
          window.location.href = "/login";
          return;
        }
        showError(e instanceof Error ? e.message : "No se pudieron cargar las facturas.");
      }
    }

    init();
  </script>
</PortalLayout>

<style>
  .facturas-body {
    padding-top: 32px;
    padding-bottom: 48px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .p-container.facturas-body {
    max-width: 1280px;
  }

  .facturas-alert { margin: 0; }

  .facturas-card { overflow: hidden; }
  .facturas-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px 14px;
    border-bottom: 1px solid var(--p-border);
  }
  .facturas-count {
    font-size: .825rem;
    color: var(--p-text-muted);
    font-weight: 500;
  }

  .facturas-desktop-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px 18px 18px;
  }
  :global(.factura-desktop) {
    border: 1px solid var(--p-border);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.26);
  }
  :global(.factura-desktop--latest) {
    border-color: rgba(79, 195, 247, 0.5);
    box-shadow:
      0 10px 24px rgba(0, 0, 0, 0.3),
      inset 3px 0 0 var(--p-accent);
    background: linear-gradient(90deg, rgba(79, 195, 247, 0.12) 0%, rgba(255, 255, 255, 0.02) 18%);
  }
  :global(.factura-desktop__main) {
    display: grid;
    grid-template-columns: minmax(220px, 1.05fr) minmax(350px, 1.65fr) minmax(170px, .85fr);
    align-items: center;
    gap: 14px;
  }
  :global(.factura-desktop__identity) {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }
  :global(.factura-desktop__meta) {
    font-size: .66rem;
    letter-spacing: .09em;
    text-transform: uppercase;
    color: var(--p-text-muted);
    font-weight: 700;
  }
  :global(.factura-desktop__cbte) {
    font-family: "Courier New", monospace;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--p-text);
    line-height: 1.2;
    white-space: nowrap;
  }
  :global(.factura-desktop__badges) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  :global(.latest-mark--desktop) {
    font-size: .62rem;
    padding: 4px 9px;
  }
  :global(.factura-desktop__grid) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }
  :global(.factura-datum) {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    min-width: 0;
  }
  :global(.factura-datum__label) {
    font-size: .65rem;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--p-text-muted);
    font-weight: 700;
  }
  :global(.factura-datum__value) {
    font-size: .92rem;
    color: var(--p-text);
    font-weight: 700;
    white-space: nowrap;
  }
  :global(.factura-desktop__summary) {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }
  :global(.factura-desktop__importe-label) {
    font-size: .65rem;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--p-text-muted);
    font-weight: 700;
  }
  :global(.factura-desktop__importe) {
    color: var(--p-accent);
    font-size: 1.28rem;
    font-weight: 900;
    letter-spacing: -.01em;
    white-space: nowrap;
    line-height: 1.15;
  }
  :global(.factura-desktop__actions) {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    padding-top: 10px;
    border-top: 1px dashed var(--p-border);
  }
  :global(.factura-desktop__actions .p-btn) {
    min-width: 120px;
    justify-content: center;
    white-space: nowrap;
  }

  :global(.latest-mark) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: .68rem;
    font-weight: 800;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #e0f2fe;
    border: 1px solid rgba(125, 211, 252, 0.7);
    background: linear-gradient(180deg, rgba(14, 116, 144, 0.55) 0%, rgba(8, 47, 73, 0.8) 100%);
    border-radius: 999px;
    padding: 4px 10px;
    white-space: nowrap;
    box-shadow:
      0 0 0 1px rgba(56, 189, 248, 0.2),
      0 8px 16px rgba(8, 47, 73, 0.35);
  }
  :global(.latest-mark__icon) {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    opacity: .95;
    flex-shrink: 0;
  }

  :global(.status-pill) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .02em;
    padding: 4px 10px;
    border-radius: 999px;
    white-space: nowrap;
    border: 1px solid transparent;
  }
  :global(.status-pill--pagada) {
    background: rgba(20, 83, 45, 0.62);
    border-color: rgba(74, 222, 128, 0.55);
    color: #dcfce7;
  }
  :global(.status-pill--deuda) {
    background: rgba(127, 29, 29, 0.62);
    border-color: rgba(248, 113, 113, 0.55);
    color: #fee2e2;
  }

  .facturas-mobile-list {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 18px 16px 20px;
  }
  :global(.factura-item) {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--p-border);
    border-radius: 16px;
    width: 100%;
    max-width: 500px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.28);
  }
  :global(.factura-item--latest) {
    border-color: rgba(79, 195, 247, 0.5);
    box-shadow:
      0 10px 24px rgba(0, 0, 0, 0.32),
      inset 3px 0 0 var(--p-accent);
    background: linear-gradient(90deg, rgba(79, 195, 247, 0.14) 0%, rgba(255, 255, 255, 0.02) 18%);
  }
  :global(.factura-item__top) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  :global(.factura-item__identity) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  :global(.factura-item__meta) {
    font-size: .68rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--p-text-muted);
    font-weight: 700;
  }
  :global(.latest-mark--mobile) {
    font-size: .62rem;
    padding: 4px 8px;
  }
  :global(.factura-item__cbte) {
    font-family: "Courier New", monospace;
    font-weight: 700;
    font-size: 1.08rem;
    color: var(--p-text);
    white-space: nowrap;
  }
  :global(.factura-item__status) {
    display: inline-flex;
    align-items: center;
  }
  :global(.factura-item__badges) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  :global(.factura-item__grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }
  :global(.factura-kv) {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
  }
  :global(.factura-kv__label) {
    font-size: .68rem;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--p-text-muted);
    font-weight: 700;
  }
  :global(.factura-kv__value) {
    font-size: .96rem;
    color: var(--p-text);
    font-weight: 700;
    line-height: 1.3;
    white-space: nowrap;
  }
  :global(.factura-kv--importe .factura-kv__value) {
    color: var(--p-accent);
    font-size: 1.14rem;
    font-weight: 900;
    letter-spacing: -.01em;
  }
  :global(.factura-item__footer) {
    display: flex;
    align-items: stretch;
    padding-top: 2px;
  }
  :global(.factura-item__actions) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    width: 100%;
  }
  :global(.factura-item__actions .p-btn) {
    justify-content: center;
    width: 100%;
  }
  :global(.factura-item__detail-btn) {
    min-width: 0;
    justify-content: center;
  }
  :global(.factura-item .status-pill) {
    font-size: .72rem;
    padding: 4px 10px;
  }

  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  @media (max-width: 768px) {
    .p-container.facturas-body {
      max-width: 1100px;
    }
    .facturas-desktop-list {
      padding: 14px;
      gap: 10px;
    }
    :global(.factura-desktop__main) {
      grid-template-columns: minmax(220px, 1fr) minmax(220px, 1fr);
      align-items: stretch;
    }
    :global(.factura-desktop__grid) {
      grid-column: 1 / -1;
    }
    :global(.factura-desktop__summary) {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 10px;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.02);
    }
  }
  @media (max-width: 560px) {
    .facturas-card__top {
      padding: 16px 16px 14px;
      justify-content: center;
    }
    .facturas-count {
      text-align: center;
    }
    .facturas-desktop-list {
      display: none;
    }
    .facturas-mobile-list {
      display: flex;
      gap: 12px;
      padding: 16px 14px 18px;
    }
    :global(.factura-item) {
      padding: 13px;
    }
    :global(.factura-item__grid) {
      grid-template-columns: 1fr 1fr;
    }
