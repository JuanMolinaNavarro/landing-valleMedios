---
interface Props {
  title: string;
  description?: string;
  /** Si true, NO renderiza el header de usuario (ej: página de login) */
  public?: boolean;
}
const { title, description = "Portal de Abonados Valle Medios", public: isPublic = false } = Astro.props;
const API_BASE_ENV = import.meta.env.PUBLIC_API_BASE ?? "http://localhost:3001/api";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Portal Valle Medios</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/img/Providers valle medios FO - Horizontal-1.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {!isPublic && (
      <header class="portal-header" id="portal-header">
        <div class="portal-header__inner">
          <a href="/facturas" class="portal-logo" aria-label="Ir a mis facturas">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="28" height="28" rx="8" fill="#1a6ef5"/>
              <path d="M7 10h14M7 14h10M7 18h8" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span>Valle Medios</span>
            <span class="portal-badge">Portal</span>
          </a>
          <nav class="portal-nav" aria-label="Navegación del portal">
            <a href="/facturas" class="portal-nav__link">Mis Facturas</a>
          </nav>
          <div class="portal-user" id="portal-user-menu">
            <button class="portal-user__btn" id="user-menu-btn" aria-expanded="false" aria-controls="user-dropdown">
              <span class="portal-user__avatar" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/>
                  <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </span>
              <span class="portal-user__name" id="user-name-display">Cargando…</span>
              <svg class="portal-user__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="portal-user__dropdown" id="user-dropdown" role="menu" hidden>
              <div class="portal-user__dropdown-info">
                <p class="dropdown-label">Abonado</p>
                <p class="dropdown-nombre" id="dropdown-nombre">—</p>
                <p class="dropdown-nro" id="dropdown-nro">—</p>
              </div>
              <div class="portal-user__dropdown-divider"></div>
              <button class="portal-user__logout" id="logout-btn" role="menuitem">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Cerrar sesión
              </button>
            </div>
          </div>
        </div>
      </header>
    )}
    <main class={isPublic ? "portal-main portal-main--public" : "portal-main"}>
      <slot />
    </main>
    {!isPublic && (
      <script define:vars={{ API_BASE: API_BASE_ENV }}>
        const _API_BASE = API_BASE;

        async function apiFetchDirect(path, init = {}) {
          const res = await fetch(`${_API_BASE}${path}`, {
            credentials: "include",
            headers: { "Content-Type": "application/json", ...(init.headers ?? {}) },
            ...init,
          });
          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            const e = new Error(err?.message || `HTTP ${res.status}`);
            e.statusCode = res.status;
            throw e;
          }
          return res.json();
        }

        async function initPortalHeader() {
          const nameEl = document.getElementById("user-name-display");
          const dropNombre = document.getElementById("dropdown-nombre");
          const dropNro = document.getElementById("dropdown-nro");

          try {
            const data = await apiFetchDirect("/auth/me");
            const user = data.user;
            const short = user.nombre.split(",")[0] ?? user.nombre;
            if (nameEl) nameEl.textContent = short;
            if (dropNombre) dropNombre.textContent = user.nombre;
            if (dropNro) dropNro.textContent = `Abonado N° ${user.nroAbonado}`;
          } catch (e) {
            if (e.statusCode === 401) {
              window.location.href = "/login";
            }
            // Si hay otro error (red, CORS al cargar), no redirigimos — la página ya maneja su propio auth
          }
        }

        // Toggle dropdown
        const btn = document.getElementById("user-menu-btn");
        const dropdown = document.getElementById("user-dropdown");
        btn?.addEventListener("click", () => {
          const isHidden = dropdown?.hidden;
          if (dropdown) dropdown.hidden = !isHidden;
          btn.setAttribute("aria-expanded", isHidden ? "true" : "false");
        });
        document.addEventListener("click", (e) => {
          if (!document.getElementById("portal-user-menu")?.contains(e.target)) {
            if (dropdown) dropdown.hidden = true;
            btn?.setAttribute("aria-expanded", "false");
          }
        });

        // Logout
        document.getElementById("logout-btn")?.addEventListener("click", async () => {
          try {
            await apiFetchDirect("/auth/logout", { method: "POST" });
          } finally {
            window.location.href = "/login";
          }
        });

        initPortalHeader();
      </script>
    )}

  </body>
</html>

<style is:global>
  /* ─── Reset ─── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --p-bg: #f4f6fb;
    --p-surface: #ffffff;
    --p-border: #e2e8f0;
    --p-text: #0f172a;
    --p-text-muted: #64748b;
    --p-accent: #1a6ef5;
    --p-accent-hover: #1557d0;
    --p-accent-light: #eff6ff;
    --p-danger: #ef4444;
    --p-success: #22c55e;
    --p-warning: #f59e0b;
    --p-header-h: 64px;
    --p-radius: 10px;
    --p-radius-lg: 16px;
    --p-shadow: 0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.06);
    --p-shadow-md: 0 4px 16px rgba(0,0,0,.1);
    --p-shadow-lg: 0 8px 32px rgba(0,0,0,.12);
    --p-font: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
    --p-ease: cubic-bezier(.4,0,.2,1);
    --p-transition: .2s var(--p-ease);
  }
  html { scroll-behavior: smooth; }
  /* Garantiza que el atributo [hidden] siempre oculte elementos,
     incluso si una clase CSS tiene display:flex/grid/block */
  [hidden] { display: none !important; }
  body {
    font-family: var(--p-font);
    background: var(--p-bg);
    color: var(--p-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  img { display: block; max-width: 100%; }
  a { text-decoration: none; color: inherit; }
  ul { list-style: none; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; }

  /* ─── Header ─── */
  .portal-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--p-header-h);
    background: var(--p-surface);
    border-bottom: 1px solid var(--p-border);
    box-shadow: var(--p-shadow);
  }
  .portal-header__inner {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .portal-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--p-text);
    text-decoration: none;
    flex-shrink: 0;
  }
  .portal-logo:hover { color: var(--p-accent); }
  .portal-badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    background: var(--p-accent-light);
    color: var(--p-accent);
    border: 1px solid #bfdbfe;
    padding: 2px 7px;
    border-radius: 100px;
  }
  .portal-nav { display: flex; align-items: center; gap: 4px; flex: 1; }
  .portal-nav__link {
    font-size: .9rem;
    font-weight: 500;
    color: var(--p-text-muted);
    padding: 6px 12px;
    border-radius: var(--p-radius);
    transition: background var(--p-transition), color var(--p-transition);
  }
  .portal-nav__link:hover { background: var(--p-accent-light); color: var(--p-accent); }
  .portal-nav__link.active { background: var(--p-accent-light); color: var(--p-accent); font-weight: 600; }

  /* ─── User menu ─── */
  .portal-user { position: relative; }
  .portal-user__btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px;
    border-radius: var(--p-radius);
    border: 1px solid var(--p-border);
    background: var(--p-surface);
    font-size: .875rem;
    font-weight: 500;
    color: var(--p-text);
    transition: background var(--p-transition), border-color var(--p-transition);
  }
  .portal-user__btn:hover { background: var(--p-bg); border-color: #c7d2e3; }
  .portal-user__avatar {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--p-accent-light);
    color: var(--p-accent);
    display: flex; align-items: center; justify-content: center;
  }
  .portal-user__chevron { color: var(--p-text-muted); transition: transform var(--p-transition); }
  .portal-user__btn[aria-expanded="true"] .portal-user__chevron { transform: rotate(180deg); }
  .portal-user__name { max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .portal-user__dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 220px;
    background: var(--p-surface);
    border: 1px solid var(--p-border);
    border-radius: var(--p-radius-lg);
    box-shadow: var(--p-shadow-lg);
    overflow: hidden;
    animation: dropIn .15s var(--p-ease);
  }
  @keyframes dropIn {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: none; }
  }
  .portal-user__dropdown-info { padding: 14px 16px; }
  .dropdown-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--p-text-muted); margin-bottom: 4px; }
  .dropdown-nombre { font-weight: 600; font-size: .875rem; color: var(--p-text); }
  .dropdown-nro { font-size: .8rem; color: var(--p-text-muted); margin-top: 2px; }
  .portal-user__dropdown-divider { height: 1px; background: var(--p-border); }
  .portal-user__logout {
    display: flex; align-items: center; gap: 8px;
    width: 100%; padding: 12px 16px;
    font-size: .875rem; font-weight: 500;
    color: var(--p-danger);
    transition: background var(--p-transition);
  }
  .portal-user__logout:hover { background: #fef2f2; }

  /* ─── Main ─── */
  .portal-main { min-height: calc(100vh - var(--p-header-h)); }
  .portal-main--public { min-height: 100vh; }

  /* ─── Shared portal utilities ─── */
  .p-container {
    width: 100%; max-width: 1100px;
    margin: 0 auto; padding: 0 24px;
  }
  .p-page-header {
    padding: 36px 0 28px;
    border-bottom: 1px solid var(--p-border);
    background: var(--p-surface);
  }
  .p-page-title {
    font-size: 1.6rem; font-weight: 800;
    letter-spacing: -.025em; color: var(--p-text);
  }
  .p-page-subtitle { font-size: .9rem; color: var(--p-text-muted); margin-top: 4px; }

  /* ─── Cards ─── */
  .p-card {
    background: var(--p-surface);
    border: 1px solid var(--p-border);
    border-radius: var(--p-radius-lg);
    box-shadow: var(--p-shadow);
  }

  /* ─── Buttons ─── */
  .p-btn {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--p-font); font-size: .875rem; font-weight: 600;
    padding: 9px 18px; border-radius: var(--p-radius);
    transition: background var(--p-transition), transform var(--p-transition), box-shadow var(--p-transition);
    cursor: pointer; border: none;
  }
  .p-btn:focus-visible { outline: 2px solid var(--p-accent); outline-offset: 2px; }
  .p-btn:active { transform: scale(.98); }

  .p-btn--primary { background: var(--p-accent); color: #fff; }
  .p-btn--primary:hover { background: var(--p-accent-hover); box-shadow: 0 4px 12px rgba(26,110,245,.3); }

  .p-btn--outline { background: transparent; color: var(--p-accent); border: 1.5px solid var(--p-accent); }
  .p-btn--outline:hover { background: var(--p-accent-light); }

  .p-btn--ghost { background: transparent; color: var(--p-text-muted); border: 1px solid var(--p-border); }
  .p-btn--ghost:hover { background: var(--p-bg); color: var(--p-text); }

  .p-btn--danger { background: var(--p-danger); color: #fff; }
  .p-btn--danger:hover { background: #dc2626; }

  .p-btn--sm { font-size: .8rem; padding: 6px 13px; }

  /* ─── Badges ─── */
  .p-badge {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: .72rem; font-weight: 700;
    padding: 3px 9px; border-radius: 100px;
    white-space: nowrap;
  }
  .p-badge--blue { background: var(--p-accent-light); color: var(--p-accent); border: 1px solid #bfdbfe; }
  .p-badge--green { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
  .p-badge--orange { background: #fff7ed; color: #c2410c; border: 1px solid #fed7aa; }

  /* ─── Status/feedback ─── */
  .p-alert {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 14px 16px; border-radius: var(--p-radius);
    font-size: .875rem; line-height: 1.5;
  }
  .p-alert--error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }
  .p-alert--success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; }
  .p-alert--info { background: var(--p-accent-light); border: 1px solid #bfdbfe; color: #1e40af; }

  /* ─── Loader ─── */
  .p-loader {
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 12px;
    padding: 60px 24px; color: var(--p-text-muted); font-size: .9rem;
  }
  .p-spinner {
    width: 36px; height: 36px;
    border: 3px solid var(--p-border);
    border-top-color: var(--p-accent);
    border-radius: 50%;
    animation: spin .8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ─── Empty state ─── */
  .p-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 12px; padding: 64px 24px; text-align: center;
    color: var(--p-text-muted);
  }
  .p-empty__icon { font-size: 2.5rem; opacity: .5; }
  .p-empty__title { font-size: 1.05rem; font-weight: 600; color: var(--p-text); }
  .p-empty__desc { font-size: .875rem; max-width: 340px; }

  /* ─── Table ─── */
  .p-table-wrap { overflow-x: auto; }
  .p-table {
    width: 100%; border-collapse: collapse;
    font-size: .875rem;
  }
  .p-table th {
    text-align: left; padding: 12px 16px;
    font-size: .72rem; font-weight: 700;
    color: var(--p-text-muted); text-transform: uppercase; letter-spacing: .07em;
    background: #f8fafc; border-bottom: 1px solid var(--p-border);
    white-space: nowrap;
  }
  .p-table td {
    padding: 14px 16px; color: var(--p-text);
    border-bottom: 1px solid var(--p-border);
    vertical-align: middle;
  }
  .p-table tbody tr { transition: background var(--p-transition); }
  .p-table tbody tr:hover { background: #f8fafc; }
  .p-table tbody tr:last-child td { border-bottom: none; }

  /* ─── Form ─── */
  .p-form-group { display: flex; flex-direction: column; gap: 6px; }
  .p-label {
    font-size: .825rem; font-weight: 600; color: var(--p-text);
  }
  .p-label--hint { font-weight: 400; color: var(--p-text-muted); margin-left: 4px; }
  .p-input {
    font-family: var(--p-font); font-size: .95rem; color: var(--p-text);
    background: var(--p-surface); border: 1.5px solid var(--p-border);
    border-radius: var(--p-radius); padding: 11px 14px;
    transition: border-color var(--p-transition), box-shadow var(--p-transition);
    outline: none; width: 100%;
  }
  .p-input:focus { border-color: var(--p-accent); box-shadow: 0 0 0 3px rgba(26,110,245,.15); }
  .p-input::placeholder { color: #94a3b8; }
  .p-input--error { border-color: var(--p-danger); }
  .p-input--error:focus { box-shadow: 0 0 0 3px rgba(239,68,68,.15); }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .portal-header__inner { padding: 0 16px; gap: 12px; }
    .portal-nav { display: none; }
    .portal-user__name { display: none; }
    .p-container { padding: 0 16px; }
    .p-page-header .p-container { padding: 0 16px; }
  }
</style>
